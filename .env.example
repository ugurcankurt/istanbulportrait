# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Iyzico Payment Configuration
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_API_KEY=your_iyzico_api_key
IYZICO_SECRET_KEY=your_iyzico_secret_key

# Payment Security - IMPORTANT: Change this from the default dummy value
# Generate a unique 11-digit identity number for payment processing
IYZICO_IDENTITY_NUMBER=12345678901

# Email Configuration (Optional)
RESEND_API_KEY=your_resend_api_key
CONTACT_EMAIL=info@istanbulportrait.com

# Application Configuration
NEXT_PUBLIC_APP_URL=https://istanbulportrait.com
NODE_ENV=production

# Analytics (Optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your_ga4_measurement_id

# Development Settings
# Set to 'true' for development mode
DEV_MODE=false